#!/usr/bin/env python3

from __future__ import annotations

import re
import subprocess
from pathlib import Path


ROOT = Path(__file__).resolve().parent.parent
DOCS_DIR = ROOT / "docs"

DOC_ORDER = [
    "implementation-plan.md",
    "proposal.md",
    "tool-taxonomy.md",
    "plugin-architecture.md",
    "testing-strategy.md",
    "packaging-distribution.md",
    "product-positioning.md",
    "go-no-go-gates.md",
    "risk-register.md",
    "history-foundation-phases.md",
    "CONTRIBUTING.md",
    "design-stable-host-worker.md",
    "investigation-dev-reload.md",
    "readme-visual-punchlist.md",
]

STYLE = """<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{title}</title>
  <style>
    :root {{
      --bg: #f4efe6;
      --paper: #fffaf2;
      --ink: #1d1a16;
      --rule: #d8cdbc;
      --accent: #8a3b12;
      --accent-soft: #efe4d4;
      --code-bg: #efe4d4;
      --muted: #6e6256;
    }}
    * {{ box-sizing: border-box; }}
    body {{
      margin: 0;
      padding: 32px 20px 64px;
      background:
        radial-gradient(circle at top left, rgba(138, 59, 18, 0.10), transparent 28%),
        linear-gradient(180deg, #efe6d7 0%, var(--bg) 100%);

      color: #5d2a10;
    }}
    p {{ margin: 0 0 16px; }}
    ul, ol {{
      margin: 0 0 18px 1.2rem;
      padding: 0;
    }}
    li {{ margin: 0 0 10px; }}
    code {{
      background: var(--code-bg);
      border-radius: 6px;
      padding: 0.08em 0.32em;
      font: 0.9em/1.4 "SFMono-Regular", Menlo, Consolas, monospace;
    }}
    pre {{
      overflow-x: auto;
      background: #241b14;
      color: #f8efe2;
      padding: 16px 18px;
      border-radius: 12px;
      margin: 0 0 18px;
    }}
    pre code {{
      background: transparent;
      padding: 0;
      color: inherit;
    }}
    a {{ color: var(--accent); }}
    .check {{
      display: inline-block;
      width: 1.35em;
      margin-left: -0.1em;
      color: var(--accent);
      font-weight: 700;
    }}
    @media (max-width: 720px) {{
      body {{ padding: 16px 12px 40px; }}
      main {{ padding: 22px 20px 28px; }}
      h1 {{ font-size: 1.7rem; }}
      h2 {{ font-size: 1.3rem; }}
    }}
  </style>
</head>
<body>
  <main>
    {nav}
    {body}
  </main>
</body>
</html>
"""


def ordered_docs() -> list[Path]:
    docs = {path.name: path for path in DOCS_DIR.glob("*.md")}
    ordered: list[Path] = []
    for name in DOC_ORDER:
        path = docs.pop(name, None)
        if path is not None:
            ordered.append(path)
    ordered.extend(sorted(docs.values(), key=lambda path: path.name.lower()))
    return ordered


def doc_title(path: Path) -> str:
    for line in path.read_text(encoding="utf-8").splitlines():
        if line.startswith("# "):
            return line[2:].strip()
    return path.stem.replace("-", " ").title()


def render_markdown(path: Path) -> str:
    try:
        from markdown_it import MarkdownIt  # type: ignore

        return MarkdownIt("commonmark", {"html": True}).render(
            path.read_text(encoding="utf-8")
        )
    except ImportError:
        return subprocess.check_output(["markdown-it", str(path)], text=True)


def rewrite_links(html: str) -> str:
    html = re.sub(
        r'href="([A-Za-z0-9._-]+)\.md(#.*?)?"',
        lambda match: f'href="{match.group(1)}.html{match.group(2) or ""}"',
        html,
    )
    html = re.sub(
        r"<li>\[(?:x|X)\]\s+",
        '<li><span class="check done">&#x2611;</span> ',
        html,
    )
    html = re.sub(
        r"<li>\[\s\]\s+",
        '<li><span class="check todo">&#x2610;</span> ',
        html,
    )
    return html


def build_nav(current: Path, docs: list[Path]) -> str:
    links = []
    for path in docs:
        title = doc_title(path)
        current_class = ' class="current"' if path.name == current.name else ""
        links.append(
            f'<li><a href="{path.stem}.html"{current_class}>{title}</a></li>'
        )
    return (
        '<nav class="doc-nav">'
        '<div class="doc-nav-title">Docs</div>'
        f'<ul class="doc-links">{"".join(links)}</ul>'
        "</nav>"
    )


def main() -> None:
    docs = ordered_docs()
    for path in docs:
        title = doc_title(path)
        body = rewrite_links(render_markdown(path))
        nav = build_nav(path, docs)
        output = STYLE.format(title=title, nav=nav, body=body)
        path.with_suffix(".html").write_text(output, encoding="utf-8")


if __name__ == "__main__":
    main()
